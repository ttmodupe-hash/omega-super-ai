# === LUQI AI v24 — Environment Configuration ===

# Server
PORT=8000
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=sqlite:///data/luqi.db

# Redis (required for real-time features)
REDIS_URL=redis://127.0.0.1:6379

# LiveKit (required for video calls)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Security
JWT_SECRET=change_this_to_a_random_string

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# Collaboration
COLLAB_SERVICE_URL=http://localhost:4000
RATE_LIMIT_MSG_PER_MIN=30
HEARTBEAT_TIMEOUT=12000
MAX_MESSAGE_LENGTH=4000

# AI
AI_MODEL=default
MAX_AI_CONTEXT_MESSAGES=20
AI_TIMEOUT_SECONDS=30

# Email (Namecheap Private Email)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USER=support@luqi-ai.com
SMTP_PASS=your_privateemail_password
FROM_EMAIL=support@luqi-ai.com
FROM_NAME=Luqi AI

# Africa-Specific
DEFAULT_REGION=west_africa
ENABLE_OFFLINE_MODE=true
WHATSAPP_ENABLED=false
