# ═══════════════════════════════════════════════════════════════════
# Luqi AI v18 — Environment Configuration
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════

# ── OPENAI (REQUIRED — AI won't work without this) ──
OPENAI_API_KEY=sk-your-openai-key-here

# ── STRIPE PAYMENTS (REQUIRED for subscriptions) ──
# Get these from https://dashboard.stripe.com/apikeys
# Use sk_test_ keys for development, sk_live_ for production
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ── EMAIL (optional — enhances delivery, falls back to mock) ──
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-key-here
# OR use SMTP as fallback:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── WEB SEARCH (optional — enhances search quality) ──
SERPER_API_KEY=your-serper-key-here

# ── MODEL SETTINGS ──
OMEGA_MODEL=gpt-4o-mini
OMEGA_VISION_MODEL=gpt-4o
OMEGA_EMBED_MODEL=text-embedding-3-small

# ── PATHS ──
OMEGA_DB_PATH=luqi_memory.db
CHROMA_PATH=./chroma_db
UPLOAD_DIR=./uploads

# ── SERVER ──
OMEGA_DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://luqi-ai.com,https://luqi-ai.com,https://www.luqi-ai.com

# ── WEB PUSH NOTIFICATIONS (optional) ──
# Generate VAPID keys with: pywebpush --gen-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CLAIM_EMAIL=support@luqi-ai.com
