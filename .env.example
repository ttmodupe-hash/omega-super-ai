# OpenAI (REQUIRED)
OPENAI_API_KEY=sk-your-openai-key-here

# Serper Web Search (optional - enables live search)
SERPER_API_KEY=your-serper-key-here

# Model Settings
OMEGA_MODEL=gpt-4o-mini
OMEGA_VISION_MODEL=gpt-4o
OMEGA_EMBED_MODEL=text-embedding-3-small

# Paths
OMEGA_DB_PATH=luqi_memory.db
CHROMA_PATH=./chroma_db
UPLOAD_DIR=./uploads

# Server
OMEGA_DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://luqi-ai.com,https://luqi-ai.com
