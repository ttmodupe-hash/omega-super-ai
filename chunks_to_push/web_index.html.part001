const getIdGuide=()=>{setIdOut(`## ${idType.replace(/_/g,' ').toUpperCase()} in ${idCountry}\n\n**Required:**\n- Birth certificate\n- Passport photo (2 copies)\n- Proof of residence\n- Application form\n\n**Steps:**\n1. Visit registration center\n2. Submit documents\n3. Biometric capture\n4. Pay fee\n5. Collect ID`)};const getBrGuide=()=>{setBrOut(`## Business: ${brType} in ${brCountry}\n\n**Steps:**\n1. Reserve name\n2. Complete form\n3. Submit ID proof\n4. Pay fee\n5. Get certificate`)};const getTxGuide=()=>{setTxOut(`## ${txType} Tax in ${txCountry}\n\n**Deadlines:**\n- Annual: March 31\n- Quarterly: 21st of following month\n\n**Steps:**\n1. Register with revenue\n2. Obtain TIN\n3. File returns\n4. Pay tax`)};const getVtGuide=()=>{setVtOut(`## Voting in ${vtCountry}\n\n**Eligibility:** Citizen aged 18+\n\n**Register:**\n1. Visit EC office\n2. Present valid ID\n3. Complete form\n4. Get voter card`)};const getPpGuide=()=>{setPpOut(`## ${ppType} Passport in ${ppCountry}\n\n**Requirements:**\n- National ID\n- Birth certificate\n- Photos\n- Fee\n\n**Steps:**\n1. Apply online or in person\n2. Pay fee\n3. Biometric capture\n4. Collect (2-6 weeks)`)};const getLdGuide=()=>{setLdOut(`## Land ${ldTx} in ${ldCountry}\n\n**Steps:**\n1. Title search\n2. Hire surveyor\n3. Prepare deed\n4. Pay stamp duty\n5. Register at land registry`)};const getSsGuide=()=>{setSsOut(`## ${ssType} in ${ssCountry}\n\n**How to Apply:**\n1. Visit ministry office\n2. Complete form\n3. Submit documents\n4. Await approval`)};const getChecklist=()=>{setDcOut(`## Checklist: ${dcPurpose} (${dcCountry})\n\n${dcPurpose==='travel'?'- Passport\n- Visa\n- Tickets\n- Insurance':dcPurpose==='business'?'- Registration\n- Tax clearance\n- Bank statements':'- National ID\n- Photos\n- Application form'}`)};return h('div',{className:'space-y-4'},h('div',{className:'flex items-center justify-between'},h('h1',{className:'text-2xl font-bold'},'Government'),h(Bd,{variant:'blue'},'Gov AI')),h('div',{className:'flex gap-2