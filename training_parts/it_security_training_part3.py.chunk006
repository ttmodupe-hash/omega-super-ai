                hints=[
                    "apktool d app.apk decompiles resources and manifest",
                    "jadx app.apk produces readable Java source code",
                    "Check for exported activities/services with no permissions",
                ],
                solution="MobSF scan reveals: Hardcoded API key in strings.xml (HIGH), Insecure SharedPreferences mode MODE_WORLD_READABLE (HIGH), Exported ContentProvider with no permissions (MEDIUM), Weak hash algorithm MD5 used (MEDIUM), No root detection implemented (LOW); Source: grep -r 'api_key' sources/; grep -r 'MODE_WORLD' sources/",
                duration_min=75, points=150,
            ),
            SecurityLab(
                id="mob_lab2", module_id="mobsec_001",
                title="Bypass SSL Pinning with Frida",
                description="Intercept HTTPS traffic from a mobile app that implements certificate pinning.",
                environment="Frida 16.x, Android emulator, Burp Suite CA cert, test app with pinning.",
                tasks=[
                    "Set up Burp Suite as proxy for Android emulator",
                    "Install Burp CA certificate on emulator",
                    "Attempt to intercept traffic without bypass (should fail)",
                    "Use Frida script to hook and bypass SSL pinning",
                    "Intercept and analyze all HTTPS requests",
                    "Modify a request in transit and observe response",
                ],
                hints=[
                    "Universal SSL Pinning Bypass script works for OkHttp and WebView",
                    "frida -U -f com.example.app -l ssl-bypass.js",
                    "Check for multiple pinning libraries (TrustKit, AFNetworking)",
                ],
                solution="frida --codeshare akabe1/frida-multiple-unpinning -U -f com.target.app --no-pause; # Or custom: Java.perform(function(){ var X509TrustManager = Java.use('javax.net.ssl.X509TrustManager'); var TrustManager = Java.registerClass({...}); }); Intercept shows API calls to /api/v1/user with Bearer token",
                duration_min=60, points=125,
            ),
            SecurityLab(
                id="mob_lab3", module_id="mobsec_001",
                title="iOS Keychain Data Extraction",
                description="Extract and analyze sensitive data stored in the iOS Keychain.",
                environment="macOS with Xcode, iOS Simulator, Objection, test iOS app.",
                tasks=[
                    "Install and configure Objection for iOS app",
                    "List all Keychain entries accessible to the app",
                    "Dump specific Keychain items with data protection class",
                    "Identify items stored with weak protection classes",
                    "Attempt Keychain extraction on jailbroken vs non-jailbroken",
                    "Document findings with remediation recommendations",
                ],
                hints=[
                    "objection --gadget com.target.app explore",
                    "ios keychain dump --json keychain.json",
                    "Look for kSecAttrAccessibleAlways (most permissive)",
                ],
                solution="objection --gadget com.example.app explore; ios keychain dump; # Shows: GenericPassword: 'user_password' with kSecAttrAccessibleAfterFirstUnlock; InternetPassword: 'api_token' with kSecAttrAccessibleAlways; Remediation: Use kSecAttrAccessibleWhenUnlockedThisDeviceOnly for highest security",
                duration_min=60, points=125,
            ),
            SecurityLab(
                id="mob_lab4", module_id="mobsec_001",
                title="Implement Certificate Pinning in Android",
                description="Add certificate pinning to an Android app and test its effectiveness.",
                environment="Android Studio, OkHttp library, test server with self-signed cert, Burp Suite.",
                tasks=[
                    "Add OkHttp CertificatePinner to network client",
                    "Pin specific certificate SHA-256 hashes",
                    "Test that app rejects untrusted certificates",
                    "Implement backup pins for certificate rotation",
                    "Add certificate pinning reporting (pin validation failure)",
                    "Test with legitimate and MitM certificates",
                ],
                hints=[
                    """CertificatePinner.Builder().add("api.example.com", "sha256/AAAAAAAA...")""",
                    "Include backup pins from different CAs",
                    "Use Certificate Transparency as additional check",
                ],
                solution="""CertificatePinner pinner = new CertificatePinner.Builder().add("api.example.com", "sha256/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=", "sha256/BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=").build(); OkHttpClient client = new OkHttpClient.Builder().certificatePinner(pinner).build();""",
                duration_min=60, points=125,
            ),
