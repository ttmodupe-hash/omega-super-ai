, duration_min=65, order=3,
            ),
            SecurityLesson(
                id="mob_l4", module_id="mobsec_001", title="Mobile API Security",
                content="Securing REST and GraphQL APIs for mobile consumption. Authentication: OAuth 2.0 + PKCE, JWT handling, refresh token rotation. Certificate pinning implementation (TrustKit, OkHttp CertificatePinner). API rate limiting, request signing, anti-tampering. Common API vulnerabilities specific to mobile clients.",
                lesson_type=LessonType.INTERACTIVE, duration_min=55, order=4,
            ),
            SecurityLesson(
                id="mob_l5", module_id="mobsec_001", title="Runtime Analysis with Frida",
                content="Dynamic instrumentation with Frida: hooking native and Java/Kotlin functions, bypassing SSL pinning, intercepting crypto operations, modifying app behavior at runtime. Script development, anti-detection techniques, and building custom Frida modules for mobile security testing.",
                lesson_type=LessonType.INTERACTIVE, duration_min=60, order=5,
            ),
            SecurityLesson(
                id="mob_l6", module_id="mobsec_001", title="Certificate Pinning & Anti-Tampering",
                content="Implementing and bypassing certificate pinning. Anti-tampering mechanisms: root detection, debugger detection, emulator detection, code integrity checks. SafetyNet/Play Integrity API integration. Obfuscation with ProGuard/R8. Runtime Application Self-Protection (RASP) basics.",
                lesson_type=LessonType.LAB, duration_min=50, order=6,
            ),
        ],
        labs=[
            SecurityLab(
                id="mob_lab1", module_id="mobsec_001",
                title="Android App Static Analysis with MobSF",
                description="Perform automated and manual static analysis on an Android APK.",
                environment="MobSF Docker container, Android emulator, test APK files, apktool, jadx.",
                tasks=[
                    "Upload APK to MobSF and review automated report",
                    "Decompile APK with apktool and jadx",
                    "Analyze AndroidManifest.xml for permissions and exported components",
                    "Search for hardcoded credentials and API keys in source",
                    "Identify insecure data storage in SharedPreferences and databases",
                    "Check for weak cryptographic implementations",
