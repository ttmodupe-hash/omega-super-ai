                    "Enable versioning and MFA delete",
                    "Configure S3 access logging and CloudTrail events",
                    "Set up Macie for sensitive data discovery",
                ],
                hints=[
                    "aws s3api get-public-access-block to check current settings",
                    "Use bucket policies to enforce encryption in transit",
                    "Enable object lock for compliance requirements",
                ],
                solution="aws s3api put-public-access-block --bucket mybucket --public-access-block-configuration BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true; aws s3api put-bucket-encryption --bucket mybucket --server-side-encryption-configuration '{\"Rules\":[{\"ApplyServerSideEncryptionByDefault\":{\"SSEAlgorithm\":\"aws:kms\",\"KMSMasterKeyID\":\"alias/my-key\"}}]}'; aws s3api put-bucket-versioning --bucket mybucket --versioning-configuration Status=Enabled",
