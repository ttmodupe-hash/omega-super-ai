                    "Install Falco for runtime threat detection",
                    "Set up OPA Gatekeeper admission control policies",
                ],
                hints=[
                    "kube-bench checks against CIS Kubernetes Benchmark",
                    "Network policies default-deny is recommended",
                    "Falco rules detect anomalous container behavior",
                ],
                solution="kubectl apply -f restricted-psp.yaml; kube-bench run --targets=master,node,etcd,policies; trivy image myapp:latest; falco -c /etc/falco/falco.yaml; kubectl apply -f network-policy-deny-all.yaml; kubectl apply -f allow-same-namespace.yaml",
                duration_min=90, points=175,
