                solution="checkov -d terraform/ --framework terraform; tfsec .; Fix: resource aws_security_group_rule allow_ssh { type=ingress from_port=22 to_port=22 protocol=tcp cidr_blocks=[var.trusted_cidr] # NOT 0.0.0.0/0 }; resource aws_ebs_volume data { encrypted = true kms_key_id = aws_kms_key.mykey.arn }",
