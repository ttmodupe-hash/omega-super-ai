# =============================================================================
# Luqi AI - Comprehensive .gitignore
# Python/FastAPI + TypeScript/Node.js + React + React Native
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---------------------------------------------------------------------------
# Python Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.coverage
coverage.*
htmlcov/
.tox/
.nox/
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# ---------------------------------------------------------------------------
# Python Virtual Environments
# ---------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ---------------------------------------------------------------------------
# Node.js / TypeScript / React / React Native
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/

# Build outputs
.next/
.nuxt/
dist/
dist-ssr/
*.local
.parcel-cache/
.cache/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# React Native
# ---------------------------------------------------------------------------
*.keystore
!debug.keystore
android/app/debug.keystore
android/build/
android/app/build/
ios/Pods/
ios/build/
*.xcworkspace
!default.xcworkspace
*.xcuserstate
project.xcworkspace/

# ---------------------------------------------------------------------------
# IDEs & Editors
# ---------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.settings/
.classpath
.project
*.code-workspace

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ---------------------------------------------------------------------------
# Windows
# ---------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Linux
# ---------------------------------------------------------------------------
*~
.nfs*

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
log/

# ---------------------------------------------------------------------------
# Data & Uploads
# ---------------------------------------------------------------------------
data/*.db
data/*.sqlite
data/*.sqlite3
uploads/
exports/

# ---------------------------------------------------------------------------
# Environment Files (keep .env.example)
# ---------------------------------------------------------------------------
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# .dockerignore

# ---------------------------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------------------------
.cache/
tmp/
temp/
*.tmp
*.temp
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.bak
*.orig
*.rej
*.patch
.secrets
.secret
